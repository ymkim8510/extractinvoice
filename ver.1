<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>거래명세서 추출기</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Noto Sans KR',sans-serif;background:#f5f4f0;color:#1a1a1a;min-height:100vh}
.wrap{max-width:1100px;margin:0 auto;padding:2rem 1.5rem}

.hdr{margin-bottom:1.5rem}
.hdr h1{font-size:22px;font-weight:600;color:#1a1a1a}
.hdr p{font-size:13px;color:#666;margin-top:4px}
.badges{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.badge{font-size:11px;padding:3px 9px;border-radius:4px;font-weight:500}
.b-blue{background:#dbeafe;color:#1d4ed8}
.b-green{background:#dcfce7;color:#16a34a}
.b-amber{background:#fef3c7;color:#b45309}

.card{background:#fff;border-radius:12px;border:1px solid #e5e5e5;padding:1.25rem 1.5rem;margin-bottom:1rem}

.drop{border:2px dashed #d1d5db;border-radius:10px;padding:2.5rem 1.5rem;text-align:center;cursor:pointer;background:#fafafa;position:relative;transition:border-color .15s,background .15s}
.drop:hover,.drop.over{border-color:#2563eb;background:#eff6ff}
.drop input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.drop-icon{font-size:2.5rem;margin-bottom:.5rem}
.drop .lbl{font-size:15px;font-weight:500;color:#1a1a1a}
.drop .sub{font-size:12px;color:#888;margin-top:4px}

.flist{display:flex;flex-direction:column;gap:6px;margin-top:.75rem}
.fi{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid #e5e5e5;border-radius:8px;padding:9px 12px}
.fi-icon{font-size:1.2rem;flex-shrink:0;color:#ef4444}
.fi-name{font-size:13px;font-weight:500;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1a1a1a}
.fi-size{font-size:11px;color:#888;flex-shrink:0}
.tag{font-size:11px;padding:2px 7px;border-radius:3px;font-weight:500;flex-shrink:0}
.tag-wait{background:#dbeafe;color:#1d4ed8}
.tag-proc{background:#fef3c7;color:#b45309}
.tag-done{background:#dcfce7;color:#16a34a}
.tag-err{background:#fee2e2;color:#b91c1c}
.tag-ocr{background:#fef3c7;color:#b45309}
.tag-txt{background:#dcfce7;color:#16a34a}
.rmv{background:none;border:none;cursor:pointer;color:#aaa;padding:2px;font-size:18px;line-height:1;flex-shrink:0}
.rmv:hover{color:#ef4444}

.prow{flex:1;display:flex;align-items:center;gap:6px}
.pbar{flex:1;height:4px;background:#f0f0f0;border-radius:2px;overflow:hidden}
.pfill{height:100%;background:#2563eb;border-radius:2px;transition:width .3s;width:0%}
.pmsg{font-size:11px;color:#888;min-width:90px;text-align:right;white-space:nowrap}

.actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:1rem}
.btn-primary{background:#1a1a1a;color:#fff;border:none;border-radius:8px;padding:10px 20px;font-size:14px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:opacity .15s}
.btn-primary:disabled{opacity:.35;cursor:not-allowed}
.btn-primary:not(:disabled):hover{opacity:.85}
.btn-sec{background:#fff;color:#1a1a1a;border:1px solid #d1d5db;border-radius:8px;padding:10px 16px;font-size:14px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:background .15s}
.btn-sec:hover{background:#f5f5f5}
.btn-sec:disabled{opacity:.35;cursor:not-allowed}

.logbox{background:#f8f8f8;border-radius:8px;padding:10px 14px;font-size:11px;color:#555;font-family:'Courier New',Consolas,monospace;max-height:110px;overflow-y:auto;margin-top:10px;display:none;line-height:1.7;border:1px solid #e5e5e5}

.sec-title{font-size:15px;font-weight:600;color:#1a1a1a;margin-bottom:.75rem;display:flex;align-items:center;gap:8px}
.sec-sub{font-size:12px;font-weight:400;color:#888}

.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:1rem}
@media(max-width:600px){.stats{grid-template-columns:repeat(2,1fr)}}
.stat{background:#f5f4f0;border-radius:8px;padding:10px 14px}
.stat .sl{font-size:11px;color:#888;margin-bottom:3px}
.stat .sv{font-size:22px;font-weight:600;color:#1a1a1a}

.tw{overflow-x:auto;border:1px solid #e5e5e5;border-radius:10px}
table{width:100%;font-size:11px;border-collapse:collapse;table-layout:fixed;min-width:1400px}
th{background:#f5f4f0;padding:8px 10px;text-align:left;font-weight:500;color:#555;border-bottom:1px solid #e5e5e5;white-space:nowrap;position:sticky;top:0;z-index:1}
td{padding:7px 10px;border-bottom:1px solid #f0f0f0;color:#1a1a1a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafafa}
td[contenteditable=true]{cursor:text}
td[contenteditable=true]:focus{outline:2px solid #2563eb;outline-offset:-1px;border-radius:2px;white-space:normal;overflow:visible;background:#fff;z-index:2;position:relative}
.fy{color:#b91c1c;font-weight:600}
.fn{color:#16a34a}

th:nth-child(1){width:100px}th:nth-child(2){width:95px}th:nth-child(3){width:100px}th:nth-child(4){width:95px}
th:nth-child(5){width:80px}th:nth-child(6){width:90px}th:nth-child(7){width:140px}th:nth-child(8){width:90px}
th:nth-child(9){width:55px}th:nth-child(10){width:50px}th:nth-child(11){width:75px}th:nth-child(12){width:90px}
th:nth-child(13){width:110px}th:nth-child(14){width:60px}th:nth-child(15){width:180px}

.notice{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:12px;color:#78350f;margin-top:.75rem;line-height:1.6}

footer{text-align:center;font-size:12px;color:#aaa;margin-top:2rem;padding-bottom:2rem}
</style>
</head>
<body>
<div class="wrap">
  <div class="hdr">
    <h1>🧾 거래명세서 추출기</h1>
    <p>PDF를 업로드하면 Claude AI가 자동으로 파싱해서 엑셀로 내려받을 수 있어요.</p>
    <div class="badges">
      <span class="badge b-green">✓ 텍스트 PDF 지원</span>
      <span class="badge b-amber">⊙ 이미지/스캔 PDF — OCR 자동 처리</span>
      <span class="badge b-blue">⬇ 납품처별 시트 분리 저장</span>
    </div>
  </div>

  <div class="card">
    <div class="drop" id="drop">
      <input type="file" id="fi" accept=".pdf" multiple/>
      <div class="drop-icon">📂</div>
      <div class="lbl">PDF 파일을 드래그하거나 클릭해서 선택하세요</div>
      <div class="sub">여러 파일 동시 선택 가능 · 텍스트 PDF / 스캔 PDF 모두 처리</div>
    </div>
    <div class="flist" id="flist"></div>
    <div class="logbox" id="log"></div>
    <div class="actions">
      <button class="btn-primary" id="runBtn" disabled>✨ AI 추출 시작</button>
      <button class="btn-sec" id="dlBtn" disabled>⬇ 엑셀 다운로드</button>
      <button class="btn-sec" id="clrBtn">↺ 초기화</button>
    </div>
    <div class="notice" id="notice" style="display:none"></div>
  </div>

  <div id="res" style="display:none">
    <div class="card">
      <div class="sec-title">추출 결과 <span class="sec-sub">— 셀을 클릭하면 직접 수정할 수 있어요</span></div>
      <div class="stats" id="stats"></div>
      <div class="tw">
        <table>
          <thead><tr>
            <th>Dealer Name</th><th>Dealer TAX ID</th><th>End User Name</th><th>End User TAX ID</th>
            <th>Document No</th><th>Date</th><th>Material Desc</th><th>Material Code</th>
            <th>Unit</th><th>Qty</th><th>EDI Code</th><th>Insurance Code</th>
            <th>Source File</th><th>Review</th><th>Review Reason</th>
          </tr></thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <footer>거래명세서 추출기 · Powered by Claude AI + Tesseract.js OCR</footer>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
const COLS=["Dealer Name","Dealer TAX ID","End User Name","End User TAX ID","Document No","Date","Material Desc","Material Code","Unit","Qty","EDI Code","Insurance Code","Source File","Review Flag","Review Reason"];
const UNITS=new Set(["BOX","DZ","EA","PAC","SET"]);

pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

let files=[];
let allRows=[];
let processing=false;

const drop=document.getElementById('drop');
const fi=document.getElementById('fi');
const flist=document.getElementById('flist');
const runBtn=document.getElementById('runBtn');
const dlBtn=document.getElementById('dlBtn');
const clrBtn=document.getElementById('clrBtn');
const logEl=document.getElementById('log');
const resEl=document.getElementById('res');
const tbody=document.getElementById('tbody');
const statsEl=document.getElementById('stats');
const notice=document.getElementById('notice');

function showNotice(msg,type='info'){
  notice.style.display='block';
  const colors={info:'background:#eff6ff;border-color:#bfdbfe;color:#1e40af',warn:'background:#fffbeb;border-color:#fde68a;color:#78350f',err:'background:#fef2f2;border-color:#fecaca;color:#991b1b'};
  notice.style.cssText=`${colors[type]||colors.info};border-radius:8px;padding:10px 14px;font-size:12px;margin-top:.75rem;line-height:1.6`;
  notice.textContent=msg;
}

function addLog(msg){logEl.style.display='block';logEl.innerHTML+=msg+'<br>';logEl.scrollTop=logEl.scrollHeight}
function clearLog(){logEl.innerHTML='';logEl.style.display='none';notice.style.display='none'}

drop.addEventListener('dragover',e=>{e.preventDefault();drop.classList.add('over')});
drop.addEventListener('dragleave',()=>drop.classList.remove('over'));
drop.addEventListener('drop',e=>{e.preventDefault();drop.classList.remove('over');handleFiles([...e.dataTransfer.files])});
fi.addEventListener('change',()=>{handleFiles([...fi.files]);fi.value=''});

function handleFiles(newFiles){
  newFiles.filter(f=>f.type==='application/pdf').forEach(f=>{
    if(!files.find(x=>x.name===f.name&&x.size===f.size))
      files.push({file:f,name:f.name,size:f.size,status:'wait',type:'?',pct:0,msg:''});
  });
  renderFiles();updateBtns();
}

function renderFiles(){
  flist.innerHTML='';
  files.forEach((item,i)=>{
    const d=document.createElement('div');d.className='fi';
    const typeTag=item.type==='ocr'?'<span class="tag tag-ocr">OCR</span>':item.type==='txt'?'<span class="tag tag-txt">텍스트</span>':'';
    const stMap={wait:'대기',proc:'처리 중',done:'완료',err:'오류'};
    const statusTag=`<span class="tag tag-${item.status}">${stMap[item.status]||item.status}</span>`;
    const prow=item.status==='proc'?`<div class="prow"><div class="pbar"><div class="pfill" id="pf${i}" style="width:${item.pct}%"></div></div><span class="pmsg" id="pm${i}">${item.msg}</span></div>`:'';
    const rmv=item.status==='wait'?`<button class="rmv" onclick="rmFile(${i})" title="삭제">×</button>`:'';
    d.innerHTML=`<span class="fi-icon">📄</span><span class="fi-name" title="${item.name}">${item.name}</span><span class="fi-size">${(item.size/1024).toFixed(0)}KB</span>${typeTag}${statusTag}${prow}${rmv}`;
    flist.appendChild(d);
  });
}

function rmFile(i){files.splice(i,1);renderFiles();updateBtns()}
function updateBtns(){
  runBtn.disabled=processing||!files.some(f=>f.status==='wait');
  dlBtn.disabled=allRows.length===0;
}

async function getPdfText(file){
  const buf=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:buf}).promise;
  let txt='';
  for(let p=1;p<=pdf.numPages;p++){
    const page=await pdf.getPage(p);
    const content=await page.getTextContent();
    const items=content.items;
    items.sort((a,b)=>{
      const ay=Math.round(a.transform[5]/5)*5,by=Math.round(b.transform[5]/5)*5;
      return ay!==by?by-ay:a.transform[4]-b.transform[4];
    });
    let ly=null,lt='';
    items.forEach(it=>{
      const y=Math.round(it.transform[5]/5)*5;
      if(ly===null)ly=y;
      if(Math.abs(y-ly)>3){txt+=lt.trim()+'\n';lt='';ly=y}
      lt+=it.str+' ';
    });
    if(lt.trim())txt+=lt.trim()+'\n';
    txt+='\n';
  }
  return txt;
}

async function isImagePdf(file){
  try{
    const buf=await file.slice(0,300000).arrayBuffer();
    const pdf=await pdfjsLib.getDocument({data:buf}).promise;
    if(!pdf.numPages)return true;
    const page=await pdf.getPage(1);
    const content=await page.getTextContent();
    const txt=content.items.map(i=>i.str).join('').trim();
    return txt.length<30;
  }catch{return true}
}

async function pdfToImages(file,onPage){
  const buf=await file.arrayBuffer();
  const pdf=await pdfjsLib.getDocument({data:buf}).promise;
  const images=[];
  for(let p=1;p<=pdf.numPages;p++){
    if(onPage)onPage(p,pdf.numPages);
    const page=await pdf.getPage(p);
    const scale=2.0;
    const vp=page.getViewport({scale});
    const canvas=document.createElement('canvas');
    canvas.width=vp.width;canvas.height=vp.height;
    await page.render({canvasContext:canvas.getContext('2d'),viewport:vp}).promise;
    images.push(canvas.toDataURL('image/png'));
  }
  return images;
}

async function ocrImages(images,onProgress){
  if(typeof Tesseract==='undefined'){
    await new Promise((res,rej)=>{
      const s=document.createElement('script');
      s.src='https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js';
      s.onload=res;s.onerror=rej;
      document.head.appendChild(s);
    });
  }
  let allText='';
  const worker=await Tesseract.createWorker('kor+eng',1,{
    logger:m=>{if(m.status==='recognizing text'&&onProgress)onProgress(m.progress)}
  });
  for(let i=0;i<images.length;i++){
    const {data:{text}}=await worker.recognize(images[i]);
    allText+=text+'\n\n';
  }
  await worker.terminate();
  return allText;
}

async function callClaude(text,fname){
  const resp=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      model:"claude-sonnet-4-20250514",
      max_tokens:4000,
      messages:[{role:"user",content:`다음은 거래명세서(납품확인서)에서 추출한 텍스트입니다. 파일명: ${fname}

---
${text.slice(0,14000)}
---

위 텍스트에서 품목별로 아래 필드를 추출해 JSON 배열로만 반환하세요.

필드:
- "Dealer Name": 공급자 상호명
- "Dealer TAX ID": 공급자 사업자등록번호 (숫자만 10자리)
- "End User Name": 납품처(구매자) 상호명
- "End User TAX ID": 납품처 사업자등록번호 (숫자만 10자리)
- "Document No": 문서번호/전표번호
- "Date": 날짜 YYYY-MM-DD
- "Material Desc": 품명
- "Material Code": 품목코드
- "Unit": BOX/DZ/EA/PAC/SET 중 하나, 없으면 ""
- "Qty": 수량 정수, 없으면 ""
- "EDI Code": EDI 코드, 없으면 ""
- "Insurance Code": 보험코드(B/M으로 시작) 또는 "비보험", 없으면 ""
- "Source File": "${fname}"

JSON 배열만 반환. 다른 텍스트 없이. 품목 없으면 [].`}]
    })
  });
  if(!resp.ok){
    const err=await resp.json().catch(()=>({}));
    throw new Error(`API 오류 ${resp.status}: ${err.error?.message||''}`);
  }
  const d=await resp.json();
  const raw=d.content.map(b=>b.text||'').join('').replace(/```json|```/g,'').trim();
  const m=raw.match(/\[[\s\S]*\]/);
  if(!m)return[];
  return JSON.parse(m[0]);
}

function addReview(rows){
  return rows.map(r=>{
    const reasons=[];
    if(!r['Date'])reasons.push('Date missing');
    if(!r['Material Code'])reasons.push('Material Code missing');
    if(!UNITS.has(String(r['Unit']||'').toUpperCase()))reasons.push('Unit invalid');
    if(r['Qty']===''||r['Qty']===null||r['Qty']===undefined)reasons.push('Qty missing');
    if(!r['Insurance Code'])reasons.push('Insurance Code missing');
    r['Review Flag']=reasons.length?'Y':'N';
    r['Review Reason']=reasons.join('; ');
    return r;
  });
}

runBtn.addEventListener('click',async()=>{
  const pending=files.filter(f=>f.status==='wait');
  if(!pending.length||processing)return;
  processing=true;runBtn.disabled=true;
  clearLog();

  for(let i=0;i<files.length;i++){
    const item=files[i];
    if(item.status!=='wait')continue;
    item.status='proc';item.pct=5;item.msg='분석 중...';renderFiles();
    addLog(`▶ ${item.name}`);

    try{
      const isImg=await isImagePdf(item.file);
      item.type=isImg?'ocr':'txt';renderFiles();
      let text='';

      if(isImg){
        addLog('  이미지 PDF 감지 → OCR 처리');
        item.msg='페이지 렌더링...';item.pct=15;renderFiles();
        const imgs=await pdfToImages(item.file,(p,t)=>{
          item.msg=`페이지 ${p}/${t}`;item.pct=15+Math.round(p/t*25);
          const el=document.getElementById(`pf${i}`);if(el)el.style.width=item.pct+'%';
          const em=document.getElementById(`pm${i}`);if(em)em.textContent=item.msg;
        });
        addLog(`  ${imgs.length}페이지 렌더링 완료`);
        item.msg='OCR 인식 중...';item.pct=40;renderFiles();
        text=await ocrImages(imgs,(pct)=>{
          item.pct=40+Math.round(pct*30);
          const el=document.getElementById(`pf${i}`);if(el)el.style.width=item.pct+'%';
          const em=document.getElementById(`pm${i}`);if(em)em.textContent=`OCR ${Math.round(pct*100)}%`;
        });
        addLog(`  OCR 완료 (${text.length}자)`);
      }else{
        addLog('  텍스트 PDF → 직접 추출');
        item.msg='텍스트 추출...';item.pct=30;renderFiles();
        text=await getPdfText(item.file);
        addLog(`  텍스트 추출 완료 (${text.length}자)`);
      }

      item.msg='AI 파싱 중...';item.pct=72;
      document.getElementById(`pf${i}`)?.style && (document.getElementById(`pf${i}`).style.width='72%');
      renderFiles();
      addLog('  Claude AI 파싱 중...');
      const rows=await callClaude(text,item.name);
      addLog(`  ✓ ${rows.length}개 품목 추출 완료`);

      allRows=allRows.concat(addReview(rows));
      item.status='done';item.pct=100;item.msg='';
    }catch(e){
      addLog(`  ✗ 오류: ${e.message}`);
      item.status='err';
      showNotice(`"${item.name}" 처리 중 오류가 발생했어요: ${e.message}`,'err');
    }
    renderFiles();
  }

  processing=false;
  renderResults();updateBtns();
  if(allRows.length)addLog(`\n✅ 전체 완료 — 총 ${allRows.length}개 품목`);
});

function renderResults(){
  if(!allRows.length){resEl.style.display='none';return}
  resEl.style.display='block';
  const rv=allRows.filter(r=>r['Review Flag']==='Y').length;
  const src=new Set(allRows.map(r=>r['Source File'])).size;
  statsEl.innerHTML=[['PDF 파일',src],['총 품목',allRows.length],['Review 필요',rv],['정상',allRows.length-rv]]
    .map(([l,v])=>`<div class="stat"><div class="sl">${l}</div><div class="sv">${v}</div></div>`).join('');

  tbody.innerHTML=allRows.map((row,ri)=>`<tr>${COLS.map(col=>{
    const v=row[col]??'';
    const ed=!['Source File','Review Flag','Review Reason'].includes(col);
    const cls=col==='Review Flag'?(v==='Y'?'fy':'fn'):'';
    return `<td class="${cls}" ${ed?`contenteditable="true" onblur="upd(${ri},'${col}',this.textContent)"`:''}  title="${String(v).replace(/"/g,'&quot;')}">${v}</td>`;
  }).join('')}</tr>`).join('');
}

window.upd=function(ri,col,val){
  allRows[ri][col]=val.trim();
  allRows[ri]=addReview([allRows[ri]])[0];
  renderResults();
}

dlBtn.addEventListener('click',()=>{
  if(!allRows.length)return;
  const wb=XLSX.utils.book_new();
  const mkSheet=rows=>{
    const data=[COLS,...rows.map(r=>COLS.map(c=>{const v=r[c]??'';return v}))];
    const ws=XLSX.utils.aoa_to_sheet(data);
    const range=XLSX.utils.decode_range(ws['!ref']);
    for(let R=1;R<=range.e.r;R++){
      const cell=ws[XLSX.utils.encode_cell({r:R,c:5})];
      if(cell&&cell.v)cell.z='yyyy-mm-dd';
    }
    return ws;
  };
  XLSX.utils.book_append_sheet(wb,mkSheet(allRows),'전체');
  const byUser={};
  allRows.forEach(r=>{
    const k=String(r['End User Name']||'').trim()||'미분류';
    if(!byUser[k])byUser[k]=[];byUser[k].push(r);
  });
  const used=['전체'];
  Object.entries(byUser).forEach(([name,rows])=>{
    let sn=name.replace(/[:\\/?*[\]]/g,'').slice(0,31)||'미분류';
    let n=2;while(used.includes(sn))sn=sn.slice(0,28)+'_'+n++;
    used.push(sn);
    XLSX.utils.book_append_sheet(wb,mkSheet(rows),sn);
  });
  const date=new Date().toISOString().slice(0,10).replace(/-/g,'');
  XLSX.writeFile(wb,`receipts_${date}.xlsx`);
});

clrBtn.addEventListener('click',()=>{
  if(processing)return;
  files=[];allRows=[];
  renderFiles();renderResults();clearLog();updateBtns();
});
</script>
</body>
</html>
